# Frontend — copy to .env before docker compose up or npm run dev
# All VITE_* variables below are required (except VITE_LIBRETRANSLATE_URL).

FRONTEND_PORT=5173

# Browser → gateway (not core/ai directly)
VITE_API_BASE_URL=http://localhost:8000

VITE_INGREDIENT_PAGE_SIZE=12
VITE_RECIPE_CATALOG_PAGE_SIZE=6
VITE_SUGGESTIONS_PAGE_SIZE=4
VITE_HISTORY_PAGE_SIZE=12
VITE_DEFAULT_MIN_MATCH_PERCENT=50

# Optional EN/BG translation (omit or leave empty to disable)
# VITE_LIBRETRANSLATE_URL=http://localhost:5000
